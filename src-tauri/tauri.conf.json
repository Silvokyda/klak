{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Klak",
  "version": "0.1.0",
  "identifier": "local.klak.operator",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Klak",
        "label": "main",
        "width": 1180,
        "height": 780,
        "minWidth": 900,
        "minHeight": 620,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; connect-src 'self' ipc: http://ipc.localhost https://api.openai.com https: wss://api.openai.com; img-src 'self' asset: http://asset.localhost data: blob:; media-src 'self' blob:",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "C:\\Users\\silvance\\AppData\\Local\\Temp\\klak\\app-icons\\**\\*"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": {
      "../sidecar/wake_listener.py": "sidecar/wake_listener.py",
      "../sidecar/requirements-wakeword.txt": "sidecar/requirements-wakeword.txt"
    }
  },
  "plugins": {
    "sql": {
      "preload": [
        "sqlite:klak.db"
      ]
    }
  }
}
