{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Klak",
  "version": "0.1.0",
  "identifier": "local.klak.operator",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Klak",
        "label": "main",
        "width": 1180,
        "height": 780,
        "minWidth": 900,
        "minHeight": 620,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:klak.db"]
    }
  }
}
